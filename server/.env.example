# Example environment variables for the server
# Replace placeholder values with real credentials in your local `.env` (do NOT commit real secrets).

# Server port
PORT=3000

# Database connection (Postgres) - example format
# postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/nocountry

# GROQ / Sanity (read-only or service key placeholder)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API key (if used)
OPENAI_API_KEY=your_openai_api_key_here

# Environment
NODE_ENV=development
