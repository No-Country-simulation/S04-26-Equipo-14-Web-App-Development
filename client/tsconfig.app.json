{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true
    },
    "include": [
        "src"
    ]
}